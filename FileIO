# Day4 topic covered are, file i/o ,txt, lis, csv, pillow, read, open , sorted , with, lambda 

keyword = "ERROR"
match = []
with open ("serverlog.txt") as file:
    for line in file:
        status,desp = line.rstrip().split(":")
        print(f"{status} : {desp}")
        if keyword in line:
            match.append(line)


with open ("criticalError.txt" , "a") as file:
    file.writelines(match)
